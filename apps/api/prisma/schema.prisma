generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  reseller
  sub_reseller
}

enum DeviceStatus {
  active
  expired
  disabled
  trial
}

enum PackageType {
  yearly
  lifetime
}

enum CreditTransactionType {
  purchase
  activation
  renewal
  transfer_in
  transfer_out
  admin_adjustment
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum RequestStatus {
  pending
  approved
  rejected
  cancelled
}

enum MacSwitchStatus {
  success
  failed
}

enum ActivationCodeStatus {
  available
  used
  expired
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String   @map("password_hash")
  name            String
  role            UserRole @default(reseller)
  parentId        String?  @map("parent_id")
  parent          User?    @relation("SubResellers", fields: [parentId], references: [id])
  subResellers    User[]   @relation("SubResellers")
  profitMargin    Decimal  @default(0) @map("profit_margin") @db.Decimal(5, 2)
  creditBalance   Decimal  @default(0) @map("credit_balance") @db.Decimal(12, 2)
  language        String   @default("en")
  isActive        Boolean  @default(true) @map("is_active")
  emailVerified        Boolean   @default(false) @map("email_verified")
  emailVerifyToken     String?   @map("email_verify_token")
  emailVerifyExpires   DateTime? @map("email_verify_expires")
  resetPasswordToken   String?   @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")
  refreshToken         String?   @map("refresh_token")
  lastLoginAt          DateTime? @map("last_login_at")
  loginAttempts        Int       @default(0) @map("login_attempts")
  lockedUntil          DateTime? @map("locked_until")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  allowedApps          String[]  @default([]) @map("allowed_apps")
  creditPasscode       String?   @map("credit_passcode")
  devices              Device[]
  creditTransactions   CreditTransaction[]
  activityLogs         ActivityLog[]
  loginLogs            LoginLog[]
  payments             Payment[]
  macSwitches          MacSwitch[]
  playlists            Playlist[]
  rechargeRequestsSent     RechargeRequest[] @relation("RechargeRequester")
  rechargeRequestsReceived RechargeRequest[] @relation("RechargeTarget")
  parentChangeRequests     ParentChangeRequest[] @relation("ChangeRequester")
  activationCodes          ActivationCode[]

  @@map("users")
}

model Device {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id])
  appId          String       @map("app_id")
  app            App          @relation(fields: [appId], references: [id])
  macAddress     String       @map("mac_address")
  macAddressAlt  String?      @map("mac_address_alt")
  packageType    PackageType  @map("package_type")
  status         DeviceStatus @default(active)
  activatedAt    DateTime     @default(now()) @map("activated_at")
  expiresAt      DateTime?    @map("expires_at")
  notes          String?
  playlistUrl    String?      @map("playlist_url")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([macAddress, appId], name: "unique_mac_per_app")
  @@index([userId])
  @@index([macAddress])
  @@index([status])
  @@index([expiresAt])
  @@map("devices")
}

model App {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  iconUrl         String   @default("") @map("icon_url")
  creditsYearly   Int      @default(1) @map("credits_yearly")
  creditsLifetime Int      @default(2) @map("credits_lifetime")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  devices   Device[]
  playlists Playlist[]

  @@map("apps")
}

model CreditPackage {
  id           String  @id @default(uuid())
  credits      Int
  bonusCredits Int     @default(0) @map("bonus_credits")
  priceUsd     Decimal @map("price_usd") @db.Decimal(10, 2)
  priceBrl     Decimal @map("price_brl") @db.Decimal(10, 2)
  isActive     Boolean @default(true) @map("is_active")

  payments Payment[]

  @@map("credit_packages")
}

model CreditTransaction {
  id           String                @id @default(uuid())
  userId       String                @map("user_id")
  user         User                  @relation(fields: [userId], references: [id])
  type         CreditTransactionType
  amount       Decimal               @db.Decimal(12, 2)
  balanceAfter Decimal               @map("balance_after") @db.Decimal(12, 2)
  referenceId  String?               @map("reference_id")
  description  String
  createdAt    DateTime              @default(now()) @map("created_at")

  @@index([userId])
  @@index([type])
  @@map("credit_transactions")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   Json     @default("{}")
  ipAddress String   @default("") @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@map("activity_logs")
}

model LoginLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  ipAddress String   @map("ip_address")
  userAgent String   @default("") @map("user_agent")
  success   Boolean
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("login_logs")
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  body      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("announcements")
}

model Payment {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  user          User          @relation(fields: [userId], references: [id])
  packageId     String        @map("package_id")
  package       CreditPackage @relation(fields: [packageId], references: [id])
  amountUsd     Decimal       @map("amount_usd") @db.Decimal(10, 2)
  paymentMethod String        @map("payment_method")
  paymentRef    String        @default("") @map("payment_ref")
  stripeSessionId String?     @map("stripe_session_id")
  status        PaymentStatus @default(pending)
  createdAt     DateTime      @default(now()) @map("created_at")

  @@index([userId])
  @@map("payments")
}

model MacSwitch {
  id            String          @id @default(uuid())
  userId        String          @map("user_id")
  user          User            @relation(fields: [userId], references: [id])
  application   String
  oldMac        String          @map("old_mac")
  newMac        String          @map("new_mac")
  status        MacSwitchStatus
  errorMessage  String?         @map("error_message")
  createdAt     DateTime        @default(now()) @map("created_at")

  @@index([userId])
  @@map("mac_switches")
}

model Playlist {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id])
  macAddress    String   @map("mac_address")
  appId         String   @map("app_id")
  app           App      @relation(fields: [appId], references: [id])
  appPlatform   String   @map("app_platform")
  playlistUrl   String   @map("playlist_url")
  playlistName  String   @default("") @map("playlist_name")
  xmlUrl        String   @default("") @map("xml_url")
  pin           String?
  isProtected   Boolean  @default(false) @map("is_protected")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([macAddress, appId])
  @@map("playlists")
}

model RechargeRequest {
  id              String        @id @default(uuid())
  requesterId     String        @map("requester_id")
  requester       User          @relation("RechargeRequester", fields: [requesterId], references: [id])
  targetId        String?       @map("target_id")
  target          User?         @relation("RechargeTarget", fields: [targetId], references: [id])
  requestFromParent Boolean     @default(false) @map("request_from_parent")
  amount          Decimal       @db.Decimal(12, 2)
  status          RequestStatus @default(pending)
  approvedAt      DateTime?     @map("approved_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([requesterId])
  @@index([targetId])
  @@map("recharge_requests")
}

model ParentChangeRequest {
  id                String        @id @default(uuid())
  requesterId       String        @map("requester_id")
  requester         User          @relation("ChangeRequester", fields: [requesterId], references: [id])
  currentParentId   String?       @map("current_parent_id")
  newParentEmail    String        @map("new_parent_email")
  status            RequestStatus @default(pending)
  actionAt          DateTime?     @map("action_at")
  createdAt         DateTime      @default(now()) @map("created_at")

  @@index([requesterId])
  @@map("parent_change_requests")
}

model ActivationCode {
  id               String                @id @default(uuid())
  userId           String                @map("user_id")
  user             User                  @relation(fields: [userId], references: [id])
  code             String                @unique
  subscriptionType PackageType           @map("subscription_type")
  status           ActivationCodeStatus  @default(available)
  linkedMac        String?               @map("linked_mac")
  linkedAt         DateTime?             @map("linked_at")
  expiresAt        DateTime?             @map("expires_at")
  createdAt        DateTime              @default(now()) @map("created_at")

  @@index([userId])
  @@index([code])
  @@map("activation_codes")
}
